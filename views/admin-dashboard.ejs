<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - DSPM</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include('_navbar', { currentPage: 'dashboard', userRole, userEmail }) %>

    <div class="container">
        <div class="page-header">
            <h2>Admin Dashboard</h2>
        </div>
        <section class="card">
            <h2>Users</h2>
            <table>
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Department</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(user => { %>
                        <tr>
                            <td><%= user.email %></td>
                            <td><%= user.role %></td>
                            <td><%= user.departments?.name || 'N/A' %></td>
                            <td><%= user.status %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </section>

        <section class="card">
            <h2>Departments</h2>
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    <% departments.forEach(dept => { %>
                        <tr>
                            <td><%= dept.name %></td>
                            <td><%= new Date(dept.created_at).toLocaleDateString() %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </section>
    </div>
</body>
</html>
